# Web3Forms public access key (https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_KEY=

# Cloudflare Turnstile site key (public, safe to expose)
# Pair with the secret key configured in your Web3Forms dashboard.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret key — DO NOT expose.
# Not used by this static site; configure in Web3Forms dashboard instead.
TURNSTILE_SECRET_KEY=
