# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated at build time — not committed
/public/screenshots/*.webp
/public/logo.webp
/public/setup/claude-cli.webp
/public/gear/macbook-m4-14.webp
/public/gear/macbook-m4-max-16.webp
/public/gear/dygma-defy.webp
/public/gear/pldt-speedtest.webp
/public/gear/realme-buds-t200-lite.webp
/public/gear/smart-5g-max.webp
/public/gear/ugreen-vertical-mouse.webp
.credentials
.ssh-credentials
secrets/
.clickup-session-context.json
